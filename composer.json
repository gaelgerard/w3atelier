{
  "name": "roots/bedrock",
  "type": "project",
  "license": "MIT",
  "description": "WordPress boilerplate with Composer, easier configuration, and an improved folder structure",
  "homepage": "https://roots.io/bedrock/",
  "authors": [
    {
      "name": "Scott Walkinshaw",
      "email": "scott.walkinshaw@gmail.com",
      "homepage": "https://github.com/swalkinshaw"
    },
    {
      "name": "Ben Word",
      "email": "ben@benword.com",
      "homepage": "https://github.com/retlehs"
    }
  ],
  "keywords": [
    "bedrock", "composer", "roots", "wordpress", "wp", "wp-config"
  ],
  "support": {
    "issues": "https://github.com/roots/bedrock/issues",
    "forum": "https://discourse.roots.io/category/bedrock"
  },
  "repositories": [
    {
      "name": "wp-packages",
      "type": "composer",
      "url": "https://repo.wp-packages.org",
      "only": [
        "wp-plugin/*",
        "wp-theme/*"
      ]
    },
    {
      "type": "vcs",
      "url": "https://github.com/gaelgerard/ggcom-mu-plugins"
    }
  ],
  "require": {
    "php": ">=8.1",
    "composer/installers": "^2.3",
    "gaelgerard/ggcom-mu-plugins": "dev-master",
    "vlucas/phpdotenv": "^5.6.3",
    "oscarotero/env": "^2.1.1",
    "roots/bedrock-autoloader": "^1.1",
    "roots/bedrock-disallow-indexing": "^2.1",
    "roots/wordpress": "^7.0",
    "roots/wp-config": "1.0.0",
    "wp-theme/twentytwentyfive": "^1.5",
    "wp-plugin/akismet": "^5.7",
    "wp-plugin/woo-cart-abandonment-recovery": "^2.1.3",
    "wp-plugin/cf7-submissions": "^0.27",
    "wp-plugin/code-snippets": "^3.9.6",
    "wp-plugin/contact-form-7": "^6.1.6",
    "wp-plugin/contact-form-7-dynamic-text-extension": "^5.0.6",
    "wp-plugin/disable-comments": "^2.7.0",
    "wp-plugin/duplicate-menu": "^0.2.3",
    "wp-plugin/duplicate-page": "^4.5",
    "wp-plugin/email-address-encoder": "^1.0.25",
    "wp-plugin/favicon-by-realfavicongenerator": "^1.3.48",
    "wp-plugin/french-slugs": "^1.0",
    "wp-plugin/duracelltomi-google-tag-manager": "^1.22.3",
    "wp-plugin/health-check": "^1.7.1",
    "wp-plugin/heartbeat-control": "^2.0.1",
    "wp-plugin/woocommerce-pdf-invoices": "^3.2.1",
    "wp-plugin/login-armor": "^2.4.0",
    "wp-plugin/post-type-switcher": "^4.0.1",
    "wp-plugin/redirection": "^5.0.0",
    "wp-plugin/search-exclude": "^2.6.5",
    "wp-plugin/sucuri-scanner": "^2.7.3",
    "wp-plugin/updraftplus": "^1.26.5",
    "wp-plugin/user-role-editor": "^4.65",
    "wp-plugin/woocommerce": "^10.9.1",
    "wp-plugin/wordpress-importer": "^0.9.5",
    "wp-plugin/wp-crontrol": "^1.21.0",
    "wp-plugin/wp-mail-logging": "^1.16.0",
    "wp-plugin/wordpress-seo": "^27.9",
    "wp-plugin/wp-super-cache": "^3.1",
    "wp-plugin/redis-cache": "^2.8"
  },
  "require-dev": {
    "laravel/pint": "^1.29.1",
    "rector/rector": "^2.4.4",
    "johnbillion/query-monitor": "^4.0.6"
  },
  "config": {
    "platform-check": false,
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "allow-plugins": {
      "composer/installers": true,
      "roots/wordpress-core-installer": true
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "extra": {
    "installer-paths": {
      "web/app/mu-plugins/{$name}/": ["type:wordpress-muplugin"],
      "web/app/plugins/{$name}/": ["type:wordpress-plugin"],
      "web/app/themes/{$name}/": ["type:wordpress-theme"]
    },
    "wordpress-install-dir": "web/wp"
  },
  "scripts": {
    "lint": "pint --test",
    "lint:fix": "pint"
  }
}
